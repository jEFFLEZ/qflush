{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "src",
    "outDir": "dist",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node", "vitest"],

    "allowJs": false,
    "checkJs": false,

    "baseUrl": "./src",
    "paths": {
      "@utils/*": ["utils/*"],
      "@daemon/*": ["daemon/*"],
      "@commands/*": ["commands/*"],
      "@rome/*": ["rome/*"],
      "@supervisor/*": ["supervisor/*"],
      "@cortex/*": ["cortex/*"],
      "@funeste38/beam": ["../node_modules/@funeste38/beam"]
    }
  },

  "include": ["src/**/*", "src/cortex/**/*"],
  "exclude": ["dist", "node_modules", "tests", "src/tests"]
}
