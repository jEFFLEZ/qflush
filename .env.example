############################################################
# QFLUSH/NPZ Daemon - ENV EXEMPLE PRÊT À L'EMPLOI
############################################################

# --- TOKENS & SÉCURITÉ ---
NEZ_ADMIN_TOKEN=sk_admin_replace_me

# --- FLOWS ---
# Flow principal utilisé pour le chat
QFLUSH_CHAT_FLOW=a11.chat.v1
# Liste des flows publics autorisés (séparés par virgule)
QFLUSH_PUBLIC_FLOWS=a11.chat.v1

# --- REDIS (optionnel) ---
#REDIS_URL=redis://127.0.0.1:6379
QFLUSH_DISABLE_REDIS=1
QFLUSH_ENABLE_REDIS=0

# --- MÉMOIRE ÉPHÉMÈRE ---
QFLUSH_EPHEMERAL_MEMORY_TTL_SEC=3600
QFLUSH_EPHEMERAL_MEMORY_MAX_TTL_SEC=86400
QFLUSH_EPHEMERAL_MEMORY_NAMESPACE=a11
QFLUSH_EPHEMERAL_MEMORY_SCOPE=shared
QFLUSH_EPHEMERAL_MEMORY_PREFIX=qflush:ephemeral

# --- PORT ---
QFLUSHD_PORT=43421

# --- AUTRES EXEMPLES (NEZ, etc.) ---
# NEZ_TOKENS=sk_pool_replace_me
# NEZ_ADMIN_TOKEN=sk_admin_replace_me
# NEZ_ALLOWED_TOKEN=sk_user_replace_me
NEZ_TOKENS=sk_pool_replace_me
NEZ_ADMIN_TOKEN=sk_admin_replace_me
NEZ_ALLOWED_TOKEN=sk_user_replace_me
# Copilot / telemetry
QFLUSH_DISABLE_COPILOT=1
QFLUSH_ENABLE_COPILOT=0
QFLUSH_COPILOT_ENABLED=0
QFLUSH_TELEMETRY=0
QFLUSH_CHAT_VERIFY=1
QFLUSH_CHAT_VERIFY_MODE=annotate
QFLUSH_CHAT_VERIFY_ANNOTATE_THRESHOLD=35
QFLUSH_CHAT_VERIFY_BLOCK_THRESHOLD=85
# QFLUSH_CHAT_VERIFY_PLACEHOLDER_DOMAINS=example.com,example.org,example.net,dummy,localhost,127.0.0.1
# QFLUSH_CHAT_VERIFY_SUCCESS_PHRASES=c'est fait,email envoye,pdf est pret,image est prete,stocke dans le bucket
QFLUSH_COPILOT_TRANSPORTS=file
QFLUSH_COPILOT_FILE_PATH=.qflush/telemetry.json
# QFLUSH_COPILOT_WEBHOOK_URL=https://hooks.slack.com/services/...
# QFLUSH_COPILOT_ALLOWED_DATA=engineState,ruleEvent,diagnostic,contextSnapshot
# QFLUSH_COPILOT_SAMPLING_RATE=1
# QFLUSH_COPILOT_MAX_PAYLOAD_SIZE=200000

# Do NOT set these here. Configure securely via secrets if needed:
# COPILOT_HMAC_SECRET=
# COPILOT_WEBHOOK_URL=
# COPILOT_BRIDGE_URL=

# Example environment variables for qflush
# Override default qflush daemon port to avoid conflicts with Spyder
QFLUSHD_PORT=43421

# Spyder admin port (override to avoid conflicts)
QFLUSH_SPYDER_ADMIN_PORT=4022

# Disable external services during CI
QFLUSH_DISABLE_REDIS=1
QFLUSH_DISABLE_COPILOT=1
QFLUSH_TELEMETRY=0

# Test token used by test helper (set in repo secrets)
QFLUSH_TEST_TOKEN=
