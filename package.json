{
  "name": "@funeste38/qflush",
  "version": "4.0.6",
  "description": "QFlush – Funesterie Command Line & Logic System (ROME, SPYDER, CORTEX, NPZ, PICCOLO, SUPERVISOR).",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Funesterie <contact@funesterie.me>",
  "homepage": "https://funesterie.me/qflush",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jEFFLEZ/qflush.git"
  },
  "bugs": {
    "url": "https://github.com/jEFFLEZ/qflush/issues"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "qflush": "dist/cli.js"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": "./dist/rome/engine.js"
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "LICENSE-*",
    "README.md",
    "README-FCL.md",
    "PUBLISH.md",
    "TRADEMARK.md",
    "installers/**/*",
    "examples/**/*"
  ],
  "scripts": {
    "build": "tsc -p .",
    "build:clean": "rimraf dist && tsc -p .",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "qflush",
    "funesterie",
    "cli",
    "rome",
    "spyder",
    "cortex",
    "npz",
    "supervisor",
    "funeste38"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@funeste38/bat": "latest",
    "@funeste38/envaptex": "latest",
    "@funeste38/freeland": "latest",
    "@funeste38/nezlephant": "latest",
    "@funeste38/qflush": "^3.1.7",
    "@funeste38/rome": "latest",
    "csv-stringify": "^6.6.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "play-sound": "^1.1.6",
    "sharp": "^0.34.5",
    "tail": "^2.2.4",
    "vitest": "^4.0.15"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "rimraf": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "publishConfig": {
    "access": "public"
  }
}
